        <script id="chunkVS" type="x-shader/x-vertex">
                varying vec2 vUv;
                void main() {
                    vUv = uv;
                    vec4 mvPosition = modelViewMatrix * vec4( position, 1.0 );
                    gl_Position = projectionMatrix * mvPosition;
                }
            </script>
        <script id="chunkFS" type="x-shader/x-fragment">
                    uniform sampler2D tilesets[$tilesetsize$];
                    uniform sampler2D data;
                    varying vec2 vUv;

                    vec2 tilePos(int tile, int columns) {
                        float textureRatio = float($chunksize$) / float(columns);
                        int y = tile / columns;
                        int x = tile - (columns * y);
                        vec2 pos = (vUv.xy - (floor(vUv.xy * float($chunksize$)) / float($chunksize$))) * textureRatio;
                        float posX = float(x) / float(columns) +                          pos.x;
                        float posY = float(y) / float(columns) + (1.0 / float(columns)) - pos.y;
                        return vec2(posX, 1.0 - posY);
                    }
                    void main() {
                        ivec4 bytes = ivec4(floor((texture2D(data, vUv) * 255.0) + 0.5));
                        int tile = ((bytes.b * 256) + bytes.g) * 256 + bytes.r;
                        vec4 color = vec4(0, 0, 0, 0);
                        $tiletest$
                        gl_FragColor = color;
                    }
                </script>
